<Application x:Class="DesktopTodo.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Startup="OnStartup">
    <Application.Resources>
        <ResourceDictionary>
            <!-- Theme resources injected at runtime -->
            <SolidColorBrush x:Key="CardBg" Color="#2a2a2a"/>
            <SolidColorBrush x:Key="TitleBg" Color="#363636"/>
            <SolidColorBrush x:Key="TextColor" Color="#e0e0e0"/>
            <SolidColorBrush x:Key="BorderColor" Color="#444"/>
            <SolidColorBrush x:Key="InputBg" Color="#1a1a1a"/>
            <SolidColorBrush x:Key="CheckIndicator" Color="#27ae60"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
